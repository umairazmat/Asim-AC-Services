# Public site URL — used for SEO metadata (Open Graph, canonical URLs).
# Must be a full URL with https:// (domain-only also works in production builds).
# Local development:
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel production (Project → Settings → Environment Variables):
# NEXT_PUBLIC_SITE_URL=https://asim-ac-services.vercel.app
