# Public site URL — used for SEO metadata, sitemap, and robots.txt.
# Must be a full URL with https:// (domain-only also works in production builds).
# Local development:
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production (Vercel → Project → Settings → Environment Variables):
# NEXT_PUBLIC_SITE_URL=https://asimacservices.com

# Lead form email (Resend) — required for /api/leads
# Create a free account at https://resend.com and add your API key.
RESEND_API_KEY=

# Where lead submissions are delivered
LEAD_TO_EMAIL=asimacservices@gmail.com

# Sender address — use a verified domain in production, e.g.:
# LEAD_FROM_EMAIL=Asim AC Services <leads@asimacservices.com>
# Until the domain is verified, Resend allows onboarding@resend.dev for testing.
LEAD_FROM_EMAIL=Asim AC Services <onboarding@resend.dev>

# Optional: WhatsApp notification to business via CallMeBot (https://www.callmebot.com)
# Owner must add CallMeBot contact on WhatsApp and get an API key.
# CALLMEBOT_API_KEY=
# CALLMEBOT_PHONE=966547524002
